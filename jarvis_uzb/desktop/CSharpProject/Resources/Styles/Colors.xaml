<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Colors -->
    <Color x:Key="Primary">#4a90e2</Color>
    <Color x:Key="PrimaryDark">#357abd</Color>
    <Color x:Key="PrimaryLight">#7bb3e8</Color>

    <!-- Secondary Colors -->
    <Color x:Key="Secondary">#7c3aed</Color>
    <Color x:Key="SecondaryDark">#5b21b6</Color>
    <Color x:Key="SecondaryLight">#a78bfa</Color>

    <!-- Background Colors -->
    <Color x:Key="Background">#0a192f</Color>
    <Color x:Key="BackgroundLight">#1a2332</Color>
    <Color x:Key="BackgroundDark">#05101f</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">White</Color>
    <Color x:Key="TextSecondary">#94a3b8</Color>
    <Color x:Key="TextMuted">#64748b</Color>

    <!-- Status Colors -->
    <Color x:Key="Success">#10b981</Color>
    <Color x:Key="Warning">#f59e0b</Color>
    <Color x:Key="Error">#ef4444</Color>
    <Color x:Key="Info">#3b82f6</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentBlue">#4a90e2</Color>
    <Color x:Key="AccentPurple">#7c3aed</Color>
    <Color x:Key="AccentGreen">#10b981</Color>
    <Color x:Key="AccentOrange">#f59e0b</Color>

    <!-- Border Colors -->
    <Color x:Key="Border">#374151</Color>
    <Color x:Key="BorderLight">#4b5563</Color>
    <Color x:Key="BorderDark">#1f2937</Color>

    <!-- Shadow Colors -->
    <Color x:Key="Shadow">#000000</Color>
    <Color x:Key="ShadowLight">#00000040</Color>

</ResourceDictionary>
