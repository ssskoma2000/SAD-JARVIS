<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Button" x:Key="JarvisButton">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="Padding" Value="20,10" />
    </Style>

    <Style TargetType="Button" x:Key="JarvisSecondaryButton" BasedOn="{StaticResource JarvisButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="2" />
    </Style>

    <Style TargetType="Label" x:Key="JarvisHeader">
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="JarvisSubHeader">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="Frame" x:Key="JarvisMessageFrame">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="15" />
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style TargetType="Frame" x:Key="JarvisUserMessage" BasedOn="{StaticResource JarvisMessageFrame}">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="Frame" x:Key="JarvisJarvisMessage" BasedOn="{StaticResource JarvisMessageFrame}">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
    </Style>

</ResourceDictionary>
